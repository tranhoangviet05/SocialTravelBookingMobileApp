APP_NAME="Social Travel Booking"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=vi_VN

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# ── PostgreSQL ──────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=social_travel_booking
DB_USERNAME=postgres
DB_PASSWORD=your_db_password

# Hoặc dùng DATABASE_URL (Railway, Render, v.v.)
# DATABASE_URL=postgresql://user:password@host:port/database

# ── Session & Cache ─────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
CACHE_STORE=database
QUEUE_CONNECTION=database

# ── Firebase ────────────────────────────────────────────────
# Đặt file service account JSON vào thư mục backend/ rồi điền tên file vào đây
FIREBASE_CREDENTIALS=firebase-service-account.json
FIREBASE_PROJECT_ID=your_firebase_project_id

# ── MoMo Payment (Sandbox) ──────────────────────────────────
# Lấy key tại: https://developers.momo.vn
MOMO_PARTNER_CODE=your_momo_partner_code
MOMO_ACCESS_KEY=your_momo_access_key
MOMO_SECRET_KEY=your_momo_secret_key
MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create
MOMO_RETURN_URL=http://localhost:8000/api/payment/momo/return
MOMO_NOTIFY_URL=http://localhost:8000/api/payment/momo/notify

# ── Gemini AI ───────────────────────────────────────────────
# Lấy key tại: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key

# ── Mail (tùy chọn) ─────────────────────────────────────────
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@socialtravelbooking.com"
MAIL_FROM_NAME="${APP_NAME}"

# ── Laravel Reverb (WebSocket Server) ──────────────────────
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=stb_app
REVERB_APP_KEY=stb_app_key
REVERB_APP_SECRET=stb_app_secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"
